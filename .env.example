# 복사해서 .env 로: cp .env.example .env  (.env 는 깃 커밋 금지)

# ── MySQL ──
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=kospi200
MYSQL_USER=kospi
MYSQL_PASSWORD=change-me

# 로컬(맥북)에서 스크립트 직접 실행 시 사용. (도커 web 컨테이너는 compose 가 host=db 로 자동 주입)
DATABASE_URL=mysql+pymysql://kospi:change-me@127.0.0.1:3306/kospi200

# ── KIS Open API (실시간) ── * 노출된 키는 재발급 권장 ──
KIS_APPKEY=
KIS_APPSECRET=
# 실전 도메인 쓰려면 변경: https://openapi.koreainvestment.com:9443
KIS_BASE=https://openapivts.koreainvestment.com:29443

# ── KRX 데이터포털 (수집/업데이트) ──
KRX_ID=
KRX_PW=

# ── 네이버 검색 API (V2 뉴스) ── developers.naver.com 에서 발급 ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# NEWS_CACHE_TTL=1800

# ── AI 요약 (Google Gemini 무료 티어, 구독자 전용) ── aistudio.google.com 에서 발급 ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── 호재/악재 분류 (V2.1) ──
# keyword(기본·무료) | ollama(무료·로컬LLM) | openai(유료)
SENTIMENT_PROVIDER=keyword
# openai 쓸 때만:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# ollama 쓸 때만(호스트에 Ollama 설치 후):
# OLLAMA_MODEL=llama3.1

# ── V3: 회원/구독 (카카오 로그인) ──
# 세션 쿠키 서명 키 — 길고 무작위한 값으로 변경
SESSION_SECRET=change-this-to-a-long-random-string
# 서비스 공개 주소(카카오 redirect 기준). 배포 시 실제 도메인/IP 로
APP_BASE_URL=http://localhost:8000
# developers.kakao.com → 내 애플리케이션 → REST API 키 / (선택)보안 client secret
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# ── 결제/구독 (Toss Payments) ── 테스트키(test_ck_/test_sk_)로 먼저, 사업자등록 후 라이브키 ──
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
SUBSCRIPTION_PRICE=4900
SUBSCRIPTION_DAYS=30
